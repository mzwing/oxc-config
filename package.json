{
  "name": "@mzwing/oxc-config",
  "version": "0.1.1",
  "description": "Opinionated Oxlint and Oxfmt configuration building on the top of @antfu/eslint-config",
  "keywords": [
    "oxc",
    "oxfmt",
    "oxlint",
    "shared-config"
  ],
  "homepage": "https://github.com/mzwing/oxc-config#readme",
  "bugs": {
    "url": "https://github.com/mzwing/oxc-config/issues"
  },
  "license": "MIT",
  "author": "mzwing",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mzwing/oxc-config.git"
  },
  "bin": {
    "oxc-config": "./bin/index.mjs"
  },
  "files": [
    "bin",
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./cli": "./dist/cli.mjs",
    "./oxfmt": "./dist/oxfmt.mjs",
    "./oxlint": "./dist/oxlint.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown --clean --dts",
    "build:inspector": "pnpm build && pnpm exec oxlint-config-inspector build --config oxlint.config.ts --out-dir ./.oxlint-config-inspector",
    "dev": "pnpm exec oxlint-config-inspector dev --config oxlint.config.ts",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "knip": "knip",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "prepack": "pnpm build",
    "prepare": "simple-git-hooks && skills-npm",
    "release": "bumpp",
    "test": "pnpm build && vitest run",
    "typecheck": "tsc --noEmit",
    "watch": "tsdown --watch"
  },
  "dependencies": {
    "@antfu/install-pkg": "^1.1.0",
    "@clack/prompts": "^1.7.0",
    "@e18e/eslint-plugin": "^0.5.1",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "ansis": "^4.3.1",
    "cac": "^7.0.0",
    "eslint-plugin-antfu": "^3.2.3",
    "eslint-plugin-command": "^3.5.3",
    "eslint-plugin-erasable-syntax-only": "^0.4.2",
    "eslint-plugin-jsdoc": "^63.2.0",
    "eslint-plugin-n": "^18.2.2",
    "eslint-plugin-regexp": "^3.1.1",
    "eslint-plugin-unicorn": "^65.0.1",
    "jsonc-parser": "^3.3.1",
    "parse-gitignore": "^2.0.0"
  },
  "devDependencies": {
    "@angular-eslint/eslint-plugin": "^22.1.0",
    "@eslint-react/eslint-plugin": "^5.17.3",
    "@types/node": "^26.1.1",
    "@unocss/eslint-plugin": "^66.7.5",
    "bumpp": "^11.1.0",
    "eslint-plugin-solid": "^0.14.5",
    "knip": "^6.27.0",
    "lint-staged": "^17.1.0",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.75.0",
    "oxlint-config-inspector": "^1.1.1",
    "oxlint-tsgolint": "^7.0.2001",
    "simple-git-hooks": "^2.13.1",
    "skills-npm": "^1.2.0",
    "svelte": "^5.56.6",
    "tinyexec": "^1.2.4",
    "tsdown": "^0.22.12",
    "tsdown-stale-guard": "^0.1.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "@angular-eslint/eslint-plugin": "^22.0.0",
    "@eslint-react/eslint-plugin": "^5.9.2",
    "@unocss/eslint-plugin": "^66.7.2",
    "eslint-plugin-solid": "^0.14.5",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.75.0",
    "oxlint-tsgolint": ">=7.0.2001",
    "svelte": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "@angular-eslint/eslint-plugin": {
      "optional": true
    },
    "@eslint-react/eslint-plugin": {
      "optional": true
    },
    "@unocss/eslint-plugin": {
      "optional": true
    },
    "eslint-plugin-solid": {
      "optional": true
    },
    "oxlint-tsgolint": {
      "optional": true
    },
    "svelte": {
      "optional": true
    }
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{cjs,cjsx,cts,ctsx,js,jsx,mjs,mjsx,mts,mtsx,ts,tsx,vue}": [
      "oxfmt --write",
      "oxlint --fix"
    ],
    "*.{css,graphql,gql,html,json,json5,jsonc,less,md,mdx,scss,svelte,toml,yaml,yml}": "oxfmt --write"
  },
  "engines": {
    "node": "^22.13.0 || >=24"
  },
  "packageManager": "pnpm@11.15.1+sha512.81350b07e53c9538a02f1f2303b4290fa2d7be04e56e2a970c4cc4b417dc761de196edabd49d55c7dc9580db81007c44143e4e3d7e462b3000d23c255122d065"
}
